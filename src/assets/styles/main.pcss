:root {
  --bg: #0f0f0f;
  --card: #1e1e1e;
  --text: #e0e0e0;
  --text-secondary: #b0b0b0;
  --accent: #0066ff;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Segoe UI', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
}